generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model HealthcheckLog {
  id        String   @id @default(cuid())
  message   String
  createdAt DateTime @default(now())
}

model Project {
  id          String   @id @default(cuid())
  code        String   @unique
  title       String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  users       User[]
  lessons     Lesson[]
}

model User {
  id         String   @id @default(cuid())
  projectId  String?
  telegramId String   @unique
  name           String?
  role           String   @default("employee")
  createdAt      DateTime @default(now())
  
  lastActivityAt DateTime?
  currentStreak  Int      @default(0)
  maxStreak      Int      @default(0)

  project    Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  progress   LessonProgress[]
  points     UserPoint[]
  aiChats    AIChatTransaction[]

  @@index([projectId])
}

model Lesson {
  id          String        @id @default(cuid())
  projectId   String?
  code        String
  title       String
  description String?
  order       Int
  isPublished Boolean       @default(true)
  createdAt   DateTime      @default(now())

  project     Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  blocks      LessonBlock[]
  progress    LessonProgress[]
  tests       Test[]
}

model LessonBlock {
  id             String   @id @default(cuid())
  lessonId        String
  type           LessonBlockType
  order          Int

  textContent    String?
  mediaUrl       String?
  telegramFileId String?
  mimeType       String?
  caption        String?

  createdAt      DateTime @default(now())

  lesson         Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([lessonId, order])
  @@index([lessonId])
}

enum LessonBlockType {
  text
  image
  audio
  video
  file
}

// -----------------------------------------------------------------------------
// USER PROGRESS & GAMIFICATION
// -----------------------------------------------------------------------------

model LessonProgress {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  status    ProgressStatus @default(started)
  score     Int?     // For tracking tests or passing thresholds
  startedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
}

enum ProgressStatus {
  started
  completed
  failed
}

model UserPoint {
  id          String   @id @default(cuid())
  userId      String
  amount      Int
  reason      String   // E.g., "lesson_completed", "quiz_passed"
  sourceId    String?  // ID of the lesson/test that granted points
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// -----------------------------------------------------------------------------
// TESTING / QUIZ
// -----------------------------------------------------------------------------

model Test {
  id          String     @id @default(cuid())
  lessonId    String
  title       String
  description String?
  passingScore Int       @default(80) // Percentage needed to pass
  createdAt   DateTime   @default(now())

  lesson      Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions   Question[]
}

model Question {
  id        String   @id @default(cuid())
  testId    String
  text      String
  order     Int
  points    Int      @default(10) // Points awarded for correct answer
  createdAt DateTime @default(now())

  test      Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  answers   Answer[]
}

model Answer {
  id         String   @id @default(cuid())
  questionId String
  text       String
  isCorrect  Boolean  @default(false)
  createdAt  DateTime @default(now())

  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

// -----------------------------------------------------------------------------
// AI INTEGRATION
// -----------------------------------------------------------------------------

model AIPersona {
  id          String   @id @default(cuid())
  projectId   String   @unique
  name        String   // Context identifier, e.g., "Angry Client", "Confused Buyer"
  prompt      String   @db.Text // The system prompt that determines AI behavior
  provider    String   @default("openai") // e.g., "openai", "anthropic"
  model       String   @default("gpt-4o") // e.g., "gpt-4o", "claude-3-5-sonnet"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AIChatTransaction {
  id            String   @id @default(cuid())
  projectId     String   // Tenant tracking for billing limits
  userId        String?  // Employee practicing
  promptTokens  Int
  completionTokens Int
  totalTokens   Int
  costEstimate  Float?   // Estimated USD cost based on model pricing
  model         String
  createdAt     DateTime @default(now())

  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([userId])
}